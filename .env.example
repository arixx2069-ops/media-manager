# App
NEXT_PUBLIC_APP_NAME=SMM Social Media Manager
# Public site URL for OAuth redirects (required in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_MODE=false

# Site login — on by default. Set REQUIRE_AUTH=false to skip the login screen.
SITE_PASSWORD=aeen-iq
AUTH_SECRET=change-this-to-a-long-random-string

# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# Groq AI — AI Advisor (key starts with gsk_ from console.groq.com)
GROQ_API_KEY=
# Optional: GROQ_MODEL=llama-3.3-70b-versatile

# xAI Grok — alternative (key starts with xai- from console.x.ai)
# XAI_API_KEY=
# GROK_MODEL=grok-3-mini

# OpenAI — optional fallback
# OPENAI_API_KEY=

# Instagram / Facebook — Meta Graph API (Business/Creator + Page required)
# https://developers.facebook.com/docs/instagram-api
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
# Instagram Business account ID (from Graph API Explorer → ig-user-id)
META_INSTAGRAM_ACCOUNT_ID=
# Facebook Page ID (numeric)
META_FACEBOOK_PAGE_ID=

# TikTok — Display API (Login Kit + user.info / video.list scopes)
# https://developers.tiktok.com/doc/display-api-get-user-info
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Telegram — Bot API (https://core.telegram.org/bots)
TELEGRAM_BOT_TOKEN=

# Google Play / Firebase (optional — for auth & push later)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
