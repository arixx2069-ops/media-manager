# App
NEXT_PUBLIC_APP_NAME=SocialMngmnt
DEMO_MODE=true

# Database (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# OpenAI — AI Advisor (set DEMO_MODE=false and add key for live advice)
OPENAI_API_KEY=

# Instagram — Meta Graph API (Business/Creator account required)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# TikTok — Marketing API / Display API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# Telegram — Bot API (https://core.telegram.org/bots)
TELEGRAM_BOT_TOKEN=

# Google Play / Firebase (optional — for auth & push later)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
